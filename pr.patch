 def sha256sum(path):
     try:
         with open(path, "rb") as f:
             h = hashlib.sha256()
             while chunk := f.read(8192):
                 h.update(chunk)
             return h.hexdigest()
     except Exception as e:
         print(f"ERR: hash failed for {path}: {e}", file=sys.stderr)
         return None
 
